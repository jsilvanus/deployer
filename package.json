{
  "name": "@jsilvanus/deployer",
  "version": "0.3.2",
  "description": "Self-hosted deployment orchestrator — REST API and MCP server for reversible deployment of Node.js, Python, and Docker apps",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "deployer": "bin/deployer.js",
    "deployer-setup": "bin/setup.js"
  },
  "files": [
    "dist/",
    "bin/",
    ".env.example",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "cp -r src/db/migrations dist/db/migrations",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jsilvanus/deployer.git"
  },
  "keywords": [
    "deployment",
    "orchestrator",
    "mcp",
    "pm2",
    "docker",
    "nginx",
    "traefik",
    "self-hosted",
    "devops"
  ],
  "author": "jsilvanus",
  "license": "MIT",
  "dependencies": {
    "@fastify/bearer-auth": "^9.3.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "better-sqlite3": "^11.9.1",
    "drizzle-orm": "^0.41.0",
    "execa": "^9.5.2",
    "prom-client": "^13.2.0",
    "fastify": "^5.3.2",
    "cron-parser": "^4.6.0",
    "node-fetch": "^3.3.2",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.13",
    "drizzle-kit": "^0.30.5",
    "fastify-plugin": "^5.1.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
}
